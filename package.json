{
  "name": "streetlight-web",
  "private": true,
  "version": "1.2.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "cap:copy": "cap copy",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "mobile:prepare:map": "node scripts/mobile/run-target.mjs map prepare",
    "mobile:prepare:hub": "node scripts/mobile/run-target.mjs hub prepare",
    "mobile:prepare:map:ios": "node scripts/mobile/run-target.mjs map prepare ios",
    "mobile:prepare:map:android": "node scripts/mobile/run-target.mjs map prepare android",
    "mobile:prepare:hub:ios": "node scripts/mobile/run-target.mjs hub prepare ios",
    "mobile:prepare:hub:android": "node scripts/mobile/run-target.mjs hub prepare android",
    "mobile:open:map:ios": "node scripts/mobile/run-target.mjs map open ios",
    "mobile:open:map:android": "node scripts/mobile/run-target.mjs map open android",
    "mobile:open:hub:ios": "node scripts/mobile/run-target.mjs hub open ios",
    "mobile:open:hub:android": "node scripts/mobile/run-target.mjs hub open android",
    "test": "npm run test:unit && npm run test:router",
    "test:unit": "vitest run",
    "test:router": "node --test src/tenant/tenantResolver.test.mjs cloudflare/tenant-router/src/router.test.mjs cloudflare/tenant-router/src/index.test.mjs",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
